{
  "name": "dodoarc",
  "version": "0.1.0",
  "description": "DodoArc - Billing OS for AI agent products with Dodo Payments and Solana-ready settlement.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node -e \"process.env.DB_PATH='C:/tmp/dodoarc-test.db'; process.env.DODO_PAYMENTS_WEBHOOK_SECRET=''; process.env.DODO_WEBHOOK_SECRET=''; process.env.ALLOW_UNSIGNED_TEST_WEBHOOKS='true'; require('jest').run(['--runInBand'])\"",
    "smoke": "node scripts/smoke-test.js",
    "check-env": "node scripts/check-env.js",
    "mcp": "node mcp.js",
    "verify-dodo": "node scripts/verify-dodo-checkout.js"
  },
  "keywords": [
    "dodo-payments",
    "solana",
    "stablecoins",
    "ai-agents",
    "billing"
  ],
  "author": "Shivam Soni",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.0",
    "better-sqlite3": "^12.9.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dodopayments": "^1.4.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "standardwebhooks": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "mcp": {
    "name": "dodoarc",
    "command": "node",
    "args": [
      "mcp.js"
    ]
  }
}
